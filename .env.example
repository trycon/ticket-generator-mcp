# Public base URL of the MCP server (used as the OAuth resource identifier / audience).
# This MUST equal OAUTH_MCP_RESOURCE_URL configured on the TG Authorization Server.
# MCP_BASE_URL=https://cf50-49-36-189-168.ngrok-free.app

# TG Authorization Server issuer URL (the TG admin gateway's public OAUTH_ISSUER).
# Access tokens are validated against ${AUTH_SERVER_ISSUER}/.well-known/jwks.json
# AUTH_SERVER_ISSUER=https://apis.ticket-generator.com

# Scopes an access token must contain to call the MCP (space-separated).
#OAUTH_REQUIRED_SCOPES="all:read all:write"

# Existing MCP server settings (unchanged)
MCP_TRANSPORT=http
HOST=0.0.0.0
PORT=3000
TG_API_KEY=
CORS_ORIGINS=
RATE_WINDOW_MS=60000
RATE_MAX=60
JSON_LIMIT=200kb
LOG_FORMAT=combined
