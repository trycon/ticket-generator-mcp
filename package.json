{
  "name": "ticket-generator-mcp",
  "version": "1.0.0",
  "description": "MCP server for Ticket Generator APIs",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "cross-env MCP_TRANSPORT=http node server.js",
    "dev": "node --watch server.js",
    "dev:http": "cross-env MCP_TRANSPORT=http node --watch server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "axios": "^1.6.0",
    "express": "^4.19.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pm2": "^5.3.0"
  },
  "keywords": ["mcp", "ticket-generator", "api", "server"],
  "engines": {
    "node": ">=18.0.0"
  }
}
